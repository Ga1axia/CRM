# Supabase (required — get from Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Brevo SMTP (optional fallback when no user credentials are set; normally each user sets Brevo in Settings)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-login@smtp-brevo.com
# SMTP_PASS=your-brevo-smtp-key
# SMTP_FROM=myfromemail@mycompany.com

# Optional: allow external schedulers (GitHub Actions, etc) to call /api/email/send-due
# without needing a logged-in user. If set, callers must provide header:
#   x-crm-secret: <this value>
# SEND_DUE_SECRET=some-long-random-secret
#
# Optional: reduce the number of emails sent per call (helps avoid timeouts on free tier)
# SEND_DUE_BATCH_LIMIT=10
